		{
			"name": "Onboarding",
			"description": "Onboarding requests are auto-created when a training appointment completes. No manual creation endpoint. Cached: list (5 min), show (10 min).",
			"item": [
				{
					"name": "List Onboardings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/onboarding?status=in_progress",
							"host": ["{{base_url}}"],
							"path": ["onboarding"],
							"query": [
								{ "key": "status", "value": "in_progress", "description": "in_progress | completed | cancelled" }
							]
						},
						"description": "Trainer sees own assigned onboardings. Sale sees onboardings from their appointments."
					},
					"response": []
				},
				{
					"name": "Get Onboarding",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    if (res.data && res.data.id) {",
									"        pm.environment.set('onboarding_id', res.data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/onboarding/{{onboarding_id}}",
							"host": ["{{base_url}}"],
							"path": ["onboarding", "{{onboarding_id}}"]
						},
						"description": "Returns full onboarding with company_info, system_analysis, policies, lessons."
					},
					"response": []
				},
				{
					"name": "Refresh Progress",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/onboarding/{{onboarding_id}}/refresh-progress",
							"host": ["{{base_url}}"],
							"path": ["onboarding", "{{onboarding_id}}", "refresh-progress"]
						},
						"description": "Trainer role. Always recalculates from DB — never uses cache. Rate limited: 10 req/min per user."
					},
					"response": []
