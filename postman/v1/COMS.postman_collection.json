		{
			"name": "Appointments",
			"description": "Full appointment lifecycle. Cached: list (5 min), show (10 min). Cache is invalidated on every write.",
			"item": [
				{
					"name": "List Appointments",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/appointments?status=pending&appointment_type=training",
							"host": ["{{base_url}}"],
							"path": ["appointments"],
							"query": [
								{ "key": "status", "value": "pending", "description": "pending | leave_office | in_progress | done | cancelled | rescheduled" },
								{ "key": "appointment_type", "value": "training", "description": "training | demo" },
								{ "key": "scheduled_date", "value": null, "disabled": true },
								{ "key": "client_id", "value": null, "disabled": true }
							]
						},
						"description": "Redis-cached per user (5 min TTL). Filters applied in-memory on the cached collection."
					},
					"response": []
				},
				{
					"name": "Create Appointment (Training)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    if (res.data && res.data.id) {",
									"        pm.environment.set('appointment_id', res.data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Initial Training - ABC Corp\",\n  \"appointment_type\": \"training\",\n  \"location_type\": \"physical\",\n  \"client_id\": \"{{client_id}}\",\n  \"system_id\": \"{{system_id}}\",\n  \"trainer_id\": \"{{trainer_id}}\",\n  \"scheduled_date\": \"2026-03-10\",\n  \"scheduled_start_time\": \"09:00\",\n  \"scheduled_end_time\": \"12:00\",\n  \"physical_location\": \"Client office — 5th floor, Phnom Penh Tower\",\n  \"notes\": \"First session covering system overview\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments",
							"host": ["{{base_url}}"],
							"path": ["appointments"]
						},
						"description": "Creates a training appointment. Demo type is restricted to sale role only. Saves `appointment_id` to environment."
					},
					"response": []
				},
				{
					"name": "Create Appointment (Demo)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Product Demo - XYZ Ltd\",\n  \"appointment_type\": \"demo\",\n  \"location_type\": \"online\",\n  \"client_id\": \"{{client_id}}\",\n  \"system_id\": \"{{system_id}}\",\n  \"trainer_id\": \"{{trainer_id}}\",\n  \"scheduled_date\": \"2026-03-05\",\n  \"scheduled_start_time\": \"14:00\",\n  \"scheduled_end_time\": \"15:30\",\n  \"meeting_link\": \"https://meet.google.com/abc-defg-hij\",\n  \"notes\": \"Online product demonstration\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments",
							"host": ["{{base_url}}"],
							"path": ["appointments"]
						},
						"description": "Demo type — sale role only. Returns 403 if trainer tries to create demo."
					},
					"response": []
				},
				{
					"name": "Get Appointment",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}"]
						},
						"description": "Redis-cached (10 min TTL)."
					},
					"response": []
				},
				{
					"name": "Update Appointment (pending only)",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scheduled_date\": \"2026-03-12\",\n  \"scheduled_start_time\": \"10:00\",\n  \"scheduled_end_time\": \"13:00\",\n  \"notes\": \"Updated schedule\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}"]
						},
						"description": "Only allowed while status=pending. Returns 403 AppointmentLockedException otherwise."
					},
					"response": []
				},
				{
					"name": "Leave Office (physical/hybrid only)",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"latitude\": 11.5564,\n  \"longitude\": 104.9282\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}/leave-office",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}", "leave-office"]
						},
						"description": "Trainer role. Transitions pending → leave_office. Not allowed for online appointments (422)."
					},
					"response": []
				},
				{
					"name": "Start Appointment",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"start_proof_media_id\": \"{{media_id}}\",\n  \"start_latitude\": 11.5600,\n  \"start_longitude\": 104.9300\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}/start",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}", "start"]
						},
						"description": "Transitions pending/leave_office → in_progress. Requires proof photo. Returns 422 if started >30 min before scheduled time."
					},
					"response": []
				},
				{
					"name": "Complete Appointment",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"end_proof_media_id\": \"{{media_id}}\",\n  \"end_latitude\": 11.5600,\n  \"end_longitude\": 104.9300,\n  \"student_count\": 12,\n  \"completion_notes\": \"All topics covered. Good engagement from the client team.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}/complete",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}", "complete"]
						},
						"description": "Transitions in_progress → done. For training type: auto-creates OnboardingRequest if not already triggered. For demo type: notifies sale."
					},
					"response": []
				},
				{
					"name": "Cancel Appointment",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cancellation_reason\": \"Client requested postponement due to internal company event.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}/cancel",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}", "cancel"]
						}
					},
					"response": []
				},
				{
					"name": "Reschedule Appointment",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scheduled_date\": \"2026-03-20\",\n  \"scheduled_start_time\": \"09:00\",\n  \"scheduled_end_time\": \"12:00\",\n  \"reschedule_reason\": \"Trainer unavailable on original date.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/appointments/{{appointment_id}}/reschedule",
							"host": ["{{base_url}}"],
							"path": ["appointments", "{{appointment_id}}", "reschedule"]
						},
						"description": "Marks old appointment as rescheduled, creates a new pending appointment. Returns new appointment_id."
					},
					"response": []
				}
			]
		},
		{
			"name": "Appointment Students",
			"description": "Manage client contacts attending an appointment.",
			"item": [
				{
					"name": "List Students",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
