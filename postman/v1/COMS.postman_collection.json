							"raw": "{{base_url}}/media",
							"host": ["{{base_url}}"],
							"path": ["media"]
						},
						"description": "Saves `media_id` to environment for use as proof photos."
					},
					"response": []
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
